# ============================================================
# Variables para Portainer → Stacks → Environment variables
# ============================================================
#
# Stack recomendado: docker-compose.yml (compila app + nginx en el servidor)
# Primera vez tarda ~5-10 min; después Portainer reutiliza caché.
#
# Alternativa rápida (requiere imagen pública en GHCR):
#   Compose path: docker-compose.ghcr.yml
#
# AUTH_SECRET — secreto aleatorio (mín. 32 caracteres)
# NEXTAUTH_URL — URL pública, ej: http://192.168.1.50:9090
# POSTGRES_PASSWORD — solo letras y números (sin @ # % etc.)
# APP_PORT — puerto en el host (default 9090)

AUTH_SECRET=cambia-esto-por-un-secreto-aleatorio-de-32-chars-min
NEXTAUTH_URL=http://localhost:9090
POSTGRES_USER=eyedbio
POSTGRES_PASSWORD=cambiaestaContrasena123
POSTGRES_DB=eyedbio
APP_PORT=9090
