# ============================================================
# Variables para Portainer → Stacks → Environment variables
# ============================================================
#
# La app descarga su imagen desde GHCR (ghcr.io/ignaciolondono/eyedbio).
# Nginx se construye en el servidor desde el repo (~10 segundos).
#
# IMPORTANTE — la imagen eyedbio debe ser accesible:
#   Opción A (recomendada): GitHub → Packages → eyedbio → Package settings
#   → Change visibility → Public
#
#   Opción B: Portainer → Registries → Add registry → Custom
#   URL: ghcr.io | Username: tu usuario GitHub
#   Password: Personal Access Token con permiso read:packages
#
# AUTH_SECRET (obligatorio en producción)
#   Secreto aleatorio de al menos 32 caracteres para sesiones.
#
# NEXTAUTH_URL (obligatorio)
#   URL pública con la que accedes a la app (sin barra final).
#   Ejemplo: http://192.168.1.50:9090
#
# POSTGRES_PASSWORD (obligatorio en producción)
#   Contraseña de la base de datos PostgreSQL.
#   Usa solo letras y números para evitar problemas en DATABASE_URL.
#
# APP_PORT (opcional, default 9090)
#   Puerto publicado en el host.

AUTH_SECRET=cambia-esto-por-un-secreto-aleatorio-de-32-chars-min
NEXTAUTH_URL=http://localhost:9090
POSTGRES_USER=eyedbio
POSTGRES_PASSWORD=cambia-esta-contrasena-segura
POSTGRES_DB=eyedbio
APP_PORT=9090
