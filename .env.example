DATABASE_URL="postgresql://eyedbio:eyedbio_secret@localhost:5432/eyedbio?schema=public"
# Conexiones máximas del pool (por instancia de la app). Ajusta según réplicas y límites de Postgres.
# DATABASE_POOL_MAX="10"
AUTH_SECRET="genera-un-secreto-aleatorio-de-32-caracteres-minimo"
NEXTAUTH_URL="http://localhost:9090"

# --- Administración (panel /admin) ---
# Opción A: variables en el servicio eyed-bio de Portainer (stack → Environment).
# Opción B: archivo /data/admin.env en el volumen (ver admin.env.example).
ADMIN_EMAIL="admin@tudominio.com"
ADMIN_PASSWORD="cambia-esta-contraseña-segura"
# ADMIN_USERNAME="admin"
# ADMIN_ENV_FILE="/data/admin.env"
UPLOAD_DIR="./uploads"
PUBLIC_MEDIA_PREFIX="/api/media"

# --- Correo (códigos de login y recuperación) — Resend ---
# 1. https://resend.com → API Keys → Create API Key
# 2. Domains → Add eyedcomun.me → copia SPF/DKIM en Cloudflare DNS → Verify
# 3. Descomenta y rellena (en local y en Portainer):
RESEND_API_KEY="re_xxxxxxxx"
RESEND_FROM="Eyed.bio <noreply@eyedcomun.me>"
#
# Pruebas sin dominio verificado: solo envía al email de tu cuenta Resend.
# RESEND_FROM="Eyed.bio <onboarding@resend.dev>"
