DATABASE_URL="postgresql://eyedbio:eyedbio_secret@localhost:5432/eyedbio?schema=public"

# --- Portainer / Docker (stack eyed-bio) — no dejes POSTGRES_* vacíos ---
# POSTGRES_USER=eyedbio
# POSTGRES_PASSWORD=eyedbio_secret
# POSTGRES_DB=eyedbio
# Si cambias usuario/contraseña tras el primer deploy, borra la carpeta postgres/ y redespliega.
# Datos en disco (Portainer): EYEDBIO_DATA_ROOT=/ruta/Eyedbio → postgres/ y uploads/ dentro.
# Conexiones máximas del pool (por instancia de la app). Ajusta según réplicas y límites de Postgres.
# DATABASE_POOL_MAX="10"
AUTH_SECRET="genera-un-secreto-aleatorio-de-32-caracteres-minimo"
NEXTAUTH_URL="http://localhost:9090"

# --- Administración (panel /admin) ---
# Opción A: variables en el servicio eyed-bio de Portainer (stack → Environment).
# Opción B: archivo /data/admin.env en el volumen (ver admin.env.example).
ADMIN_EMAIL="admin@tudominio.com"
ADMIN_PASSWORD="cambia-esta-contraseña-segura"
# ADMIN_USERNAME="admin"
# ADMIN_ENV_FILE="/data/admin.env"
UPLOAD_DIR="./uploads"
PUBLIC_MEDIA_PREFIX="/api/media"

# --- Correo (códigos de login y recuperación) — Resend ---
# 1. https://resend.com → API Keys → Create API Key
# 2. Domains → Add eyedcomun.me → copia SPF/DKIM en Cloudflare DNS → Verify
# 3. Descomenta y rellena (en local y en Portainer):
RESEND_API_KEY="re_xxxxxxxx"
RESEND_FROM="Eyed.bio <noreply@eyedcomun.me>"
#
# Pruebas sin dominio verificado: solo envía al email de tu cuenta Resend.
# RESEND_FROM="Eyed.bio <onboarding@resend.dev>"

# --- Inicio de sesión social (OAuth) ---
# OAUTH_ENABLED=off desactiva todos los inicios de sesión social y oculta los botones.
# Por defecto: on (activo si hay credenciales configuradas abajo).
# OAUTH_ENABLED=on
#
# Solo aparecen los botones de las plataformas con ID y secret configurados.
# Redirect URI en cada consola: {NEXTAUTH_URL}/api/auth/callback/{provider}
# Ejemplo producción: https://eyedbio.eyedcomun.me/api/auth/callback/google
#
# Google: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
#
# Discord: https://discord.com/developers/applications → OAuth2
# DISCORD_CLIENT_ID=""
# DISCORD_CLIENT_SECRET=""
#
# GitHub: Settings → Developer settings → OAuth Apps
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
#
# Twitch: https://dev.twitch.tv/console/apps
# TWITCH_CLIENT_ID=""
# TWITCH_CLIENT_SECRET=""

# --- Presencia Discord (EyedBot) ---
# Misma EYEDBOT_API_KEY que en el servidor de EyedBot (openssl rand -base64 32).
# El usuario debe estar en EyedComun (https://discord.gg/eN6eQdGn87) con actividad visible.
# EYEDBOT_PRESENCE_URL="https://eyedbot.eyedcomun.me/api/presence"
# EYEDBOT_API_KEY=""
# LANYARD_FALLBACK=off   # on = usar api.lanyard.rest si EyedBot no responde

# --- Moderación de imágenes y vídeos (desactivada por defecto) ---
# Activar: CONTENT_MODERATION=on
# Opción A (recomendada): https://sightengine.com → API credentials
# SIGHTENGINE_API_USER="tu_usuario"
# SIGHTENGINE_API_SECRET="tu_secreto"
# Opción B: OpenAI Vision (gpt-4o-mini analiza cada subida)
# OPENAI_API_KEY="sk-..."
# OPENAI_MODERATION_MODEL="gpt-4o-mini"
