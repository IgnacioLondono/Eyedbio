DATABASE_URL="postgresql://eyedbio:eyedbio_secret@localhost:5432/eyedbio?schema=public"
# Conexiones máximas del pool (por instancia de la app). Ajusta según réplicas y límites de Postgres.
# DATABASE_POOL_MAX="10"
AUTH_SECRET="genera-un-secreto-aleatorio-de-32-caracteres-minimo"
NEXTAUTH_URL="http://localhost:9090"
UPLOAD_DIR="./uploads"
PUBLIC_MEDIA_PREFIX="/api/media"

# --- Correo para códigos de recuperación de contraseña ---
# Opción A (recomendada): Resend — https://resend.com — API key gratis
# RESEND_API_KEY="re_xxxxxxxx"
# RESEND_FROM="Eyed.bio <noreply@tudominio.com>"

# Opción B: SMTP (Gmail usa contraseña de aplicación, no la normal)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="tu@gmail.com"
# SMTP_PASS="contraseña-de-aplicacion-de-16-caracteres"
# SMTP_FROM="Eyed.bio <tu@gmail.com>"
