generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  username            String               @unique
  displayName         String
  bio                 String               @default("")
  avatarUrl           String?
  backgroundUrl       String?
  backgroundType      String               @default("image")
  audioUrl            String?
  audioStartTime      Float                @default(0)
  audioEnabled        Boolean              @default(false)
  views               Int                  @default(0)
  badges              String               @default("[]")
  settings            String               @default("{}")
  usernameChangedAt   DateTime?
  accessCodeEnabled   Boolean              @default(false)
  accessCodeHash      String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  links               SocialLink[]
  passwordResetTokens       PasswordResetToken[]
  loginVerificationTokens   LoginVerificationToken[]

  profileViewsAsViewer        ProfileView[] @relation("ProfileViewViewer")
  profileViewsAsProfileUser   ProfileView[] @relation("ProfileViewProfileUser")
}

model ProfileView {
  id              String   @id @default(cuid())
  viewerId        String
  viewer          User     @relation("ProfileViewViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  profileUserId  String
  profileUser    User     @relation("ProfileViewProfileUser", fields: [profileUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@unique([viewerId, profileUserId])
  @@index([profileUserId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model LoginVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model SocialLink {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String
  url       String
  label     String?
  iconUrl   String?
  sortOrder Int     @default(0)
}
