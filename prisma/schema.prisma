generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String?
  username            String               @unique
  publicUid           String               @unique
  role                String               @default("user")
  blockedAt           DateTime?
  blockedReason       String?
  displayName         String
  bio                 String               @default("")
  avatarUrl           String?
  backgroundUrl       String?
  backgroundType      String               @default("image")
  audioUrl            String?
  audioStartTime      Float                @default(0)
  audioClipDuration   Float                @default(30)
  audioEnabled        Boolean              @default(false)
  audioSource         String               @default("upload")
  views               Int                  @default(0)
  badges              String               @default("[]")
  locale              String               @default("es")
  settings            String               @default("{}")
  usernameChangedAt   DateTime?
  accessCodeEnabled   Boolean              @default(false)
  accessCodeHash      String?
  loginCodeEnabled    Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  links               SocialLink[]
  accounts            Account[]
  passwordResetTokens       PasswordResetToken[]
  loginVerificationTokens   LoginVerificationToken[]

  profileViewsAsViewer        ProfileView[] @relation("ProfileViewViewer")
  profileViewsAsProfileUser   ProfileView[] @relation("ProfileViewProfileUser")
  profileViewsAsGuest         ProfileViewGuest[]
  reviewsWritten              ProfileReview[] @relation("ReviewsWritten")
  reviewsReceived             ProfileReview[] @relation("ReviewsReceived")
  supportTickets              SupportTicket[]
}

model SupportTicket {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String
  subject   String
  status    String            @default("open")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  messages  SupportMessage[]

  @@index([userId])
  @@index([status, updatedAt(sort: Desc)])
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String?
  isStaff   Boolean       @default(false)
  body      String        @db.Text
  createdAt DateTime      @default(now())

  @@index([ticketId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model ProfileView {
  id              String   @id @default(cuid())
  viewerId        String
  viewer          User     @relation("ProfileViewViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  profileUserId  String
  profileUser    User     @relation("ProfileViewProfileUser", fields: [profileUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@unique([viewerId, profileUserId])
  @@index([profileUserId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model LoginVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model ProfileViewGuest {
  id            String   @id @default(cuid())
  profileUserId String
  profileUser   User     @relation(fields: [profileUserId], references: [id], onDelete: Cascade)
  guestId       String
  createdAt     DateTime @default(now())

  @@unique([profileUserId, guestId])
  @@index([profileUserId])
}

model ProfileReview {
  id            String   @id @default(cuid())
  reviewerId    String
  reviewer      User     @relation("ReviewsWritten", fields: [reviewerId], references: [id], onDelete: Cascade)
  profileUserId String
  profileUser   User     @relation("ReviewsReceived", fields: [profileUserId], references: [id], onDelete: Cascade)
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([reviewerId, profileUserId])
  @@index([profileUserId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model SiteSettings {
  id        String   @id @default("default")
  config    String   @default("{}")
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String
  url       String
  label     String?
  iconUrl   String?
  clicks    Int     @default(0)
  sortOrder Int     @default(0)
}
