# ============================================================
# Variables para Portainer → Stacks → Environment variables
# ============================================================
#
# Stack recomendado: docker-compose.ghcr.yml en la raíz (wrapper) o docker/compose/docker-compose.ghcr.yml
# Primera vez tarda ~5-10 min; después Portainer reutiliza caché.
#
# Alternativa rápida (requiere imagen pública en GHCR):
#   Compose path: docker/compose/docker-compose.ghcr.yml
#
# AUTH_SECRET — secreto aleatorio (mín. 32 caracteres)
# NEXTAUTH_URL — URL pública, ej: http://192.168.1.50:9090
# POSTGRES_PASSWORD — solo letras y números (sin @ # % etc.)
# APP_PORT — puerto en el host (default 9090)

AUTH_SECRET=cambia-esto-por-un-secreto-aleatorio-de-32-chars-min
NEXTAUTH_URL=https://eyedbio.eyedcomun.me
POSTGRES_USER=eyedbio
POSTGRES_PASSWORD=cambiaestaContrasena123
POSTGRES_DB=eyedbio
APP_PORT=9090

# --- Cloudflare Tunnel (recomendado si el 502 viene de cloudflared en otra red) ---
# 1. Activa el servicio cloudflared del stack:
#    COMPOSE_PROFILES=tunnel
# 2. Token del túnel (Zero Trust → Networks → Tunnels → Configure → token)
# 3. Public Hostname eyedbio.eyedcomun.me → Service URL:
#      http://nginx:9090
#    (nombre del servicio compose en eyed-bio-net; NO uses 192.168.x.x)
# 4. Si otro cloudflared (cloudflare3) comparte el mismo túnel, conéctalo también:
#      docker network connect eyed-bio-net cloudflare3-cloudflared-2-1
#    o deja solo eyed-bio-cloudflared como conector de ese hostname.
# COMPOSE_PROFILES=tunnel
# CLOUDFLARE_TUNNEL_TOKEN=

# --- OAuth login (Google, Discord, GitHub, Twitch) ---
# Redirect en cada consola: {NEXTAUTH_URL}/api/auth/callback/{provider}
# Discord Developer Portal → OAuth2 → Redirects:
#   https://eyedbio.eyedcomun.me/api/auth/callback/discord
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Carpeta en disco con espacio (bind mount). Sin barra final.
# Ejemplo OMV/disco extra:
# EYEDBIO_DATA_ROOT=/srv/dev-disk-by-uuid-a5b4e34c-5e9b-430c-93ad-0473fe6143d2/data/Etc/Eyedbio
EYEDBIO_DATA_ROOT=/srv/dev-disk-by-uuid-a5b4e34c-5e9b-430c-93ad-0473fe6143d2/data/Etc/Eyedbio

# --- Resend (correos de login / recuperación) ---
# Resend → API Keys + verificar dominio eyedcomun.me (DNS en Cloudflare)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Eyed.bio <noreply@eyedcomun.me>

# --- Presencia Discord (EyedBot) — misma clave que en EyedBot ---
# EYEDBOT_PRESENCE_URL=https://eyedbot.eyedcomun.me/api/presence
# EYEDBOT_API_KEY=   # misma clave en EyedBot y Eyed.bio (vincular Discord desde dashboard)
# LANYARD_FALLBACK=off
